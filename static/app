// ---- Toast Notifications ----
function showToast(message, type = 'info') {
    let container = document.querySelector('.toast-container');
    if (!container) {
        container = document.createElement('div');
        container.className = 'toast-container';
        document.body.appendChild(container);
    }
    const toast = document.createElement('div');
    toast.className = `toast toast-${type}`;
    toast.textContent = message;
    container.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
}
// Toggle the 3-line menu visibility
function toggleMenu() {
    const menu = document.getElementById('dropdown-menu');
    if (menu) menu.classList.toggle('active');
}

// Function to set specific theme
function setTheme(mode) {
    const body = document.body;
    if (mode === 'light') {
        body.classList.add('light-theme');
        localStorage.setItem('theme', 'light');
    } else {
        body.classList.remove('light-theme');
        localStorage.setItem('theme', 'dark');
    }
    toggleMenu();
}

// Close menu if clicking outside of it
window.addEventListener('click', (e) => {
    const menu = document.getElementById('dropdown-menu');
    const burger = document.querySelector('.hamburger-menu');
    if (menu && burger && menu.classList.contains('active') && !menu.contains(e.target) && !burger.contains(e.target)) {
        menu.classList.remove('active');
    }
});

// Load saved theme on boot
document.addEventListener('DOMContentLoaded', () => {
    if (localStorage.getItem('theme') === 'light') {
        document.body.classList.add('light-theme');
    }
});
// ---- API Helper ----
async function api(url, options = {}) {
    try {
        const res = await fetch(url, {
            headers: { 'Content-Type': 'application/json', ...options.headers },
            ...options,
        });
        const data = await res.json();
        if (!res.ok) {
            throw new Error(data.detail || 'Request failed');
        }
        return data;
    } catch (err) {
        showToast(err.message, 'error');
        throw err;
    }
}

async function apiForm(url, formData) {
    try {
        const res = await fetch(url, { method: 'POST', body: formData });
        const data = await res.json();
        if (!res.ok) {
            throw new Error(data.detail || 'Request failed');
        }
        return data;
    } catch (err) {
        showToast(err.message, 'error');
        throw err;
    }
}

// ---- Auth ----
async function handleLogin(e) {
    e.preventDefault();
    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;
    try {
        const data = await api('/auth/login', {
            method: 'POST',
            body: JSON.stringify({ email, password }),
        });
        showToast('Login successful!', 'success');
        setTimeout(() => {
            if (data.role === 'admin') {
                window.location.href = '/admin-dashboard';
            } else {
                window.location.href = '/user-dashboard';
            }
        }, 500);
    } catch (err) { /* handled by api() */ }
}

async function handleRegister(e) {
    e.preventDefault();
    const name = document.getElementById('name').value;
    const email = document.getElementById('email').value;
    const password = document.getElementById('password').value;
    const confirmPassword = document.getElementById('confirm_password').value;
    if (password !== confirmPassword) {
        showToast('Passwords do not match', 'error');
        return;
    }
    try {
        await api('/auth/register', {
            method: 'POST',
            body: JSON.stringify({ name, email, password }),
        });
        showToast('Registration successful! Please login.', 'success');
        setTimeout(() => window.location.href = '/login', 1000);
    } catch (err) { /* handled */ }
}

async function handleLogout() {
    await api('/auth/logout', { method: 'POST' });
    window.location.href = '/login';
}

// ---- Admin: Upload PDF ----
async function handleUploadPDF(e) {
    e.preventDefault();
    const form = e.target;
    const formData = new FormData(form);
    try {
        await apiForm('/admin/upload', formData);
        showToast('PDF uploaded successfully!', 'success');
        form.reset();
        loadAdminPDFs();
    } catch (err) { /* handled */ }
}

// ---- Admin: Load PDFs for Dashboard (Cards) ----
async function loadAdminPDFs() {
    const container = document.getElementById('pdfs-list');
    if (!container) return;
    try {
        const pdfs = await api('/admin/pdfs');
        if (pdfs.length === 0) {
            container.innerHTML = `<div class="empty-state"><div class="icon">📁</div><p>No PDFs uploaded yet. Start by uploading one!</p></div>`;
            return;
        }
        container.innerHTML = pdfs.map(pdf => `
            <div class="card" style="animation: slideUp 0.5s ease">
                <div class="card-header">
                    <span class="card-title">📄 ${escapeHtml(pdf.title)}</span>
                    <button class="btn btn-danger btn-sm" onclick="deletePDF(${pdf.id})">🗑 Delete</button>
                </div>
                <p class="card-desc">${escapeHtml(pdf.description || 'No description available')}</p>
                <div class="card-meta">
                    <span>📅 ${formatDate(pdf.upload_date)}</span>
                </div>
            </div>
        `).join('');
        updateStatCount('pdf-count', pdfs.length);
    } catch (err) { /* handled */ }
}

// ---- Admin: Load PDFs for List Page (Table) ----
async function loadAdminPDFsList() {
    const container = document.getElementById('pdfs-table-body');
    if (!container) return;
    try {
        const pdfs = await api('/admin/pdfs');
        if (pdfs.length === 0) {
            container.innerHTML = `<tr><td colspan="5" class="empty-state"><div class="icon">📁</div><p>No PDFs uploaded yet</p></td></tr>`;
            return;
        }
        container.innerHTML = pdfs.map(pdf => `
            <tr>
                <td>${pdf.id}</td>
                <td><strong>${escapeHtml(pdf.title)}</strong></td>
                <td>${escapeHtml(pdf.description || '—')}</td>
                <td>${formatDate(pdf.upload_date)}</td>
                <td>
                    <button class="btn btn-danger btn-sm" onclick="deletePDF(${pdf.id}, true)">🗑 Delete</button>
                </td>
            </tr>
        `).join('');
    } catch (err) { /* handled */ }
}

// ---- Admin: Delete PDF ----
async function deletePDF(id, isTable = false) {
    if (!confirm('Are you sure you want to delete this PDF? This will remove all associated permissions and applications.')) return;
    try {
        await api(`/admin/pdfs/${id}`, { method: 'DELETE' });
        showToast('PDF deleted successfully!', 'success');
        if (isTable) {
            loadAdminPDFsList();
        } else {
            loadAdminPDFs();
        }
    } catch (err) { /* handled */ }
}

// ---- Admin: Load Applications ----
async function loadApplications() {
    const container = document.getElementById('applications-list');
    if (!container) return;
    try {
        const apps = await api('/admin/applications');
        if (apps.length === 0) {
            container.innerHTML = `<div class="empty-state"><div class="icon">📋</div><p>No applications submitted yet</p></div>`;
            return;
        }
        container.innerHTML = apps.map(app => `
            <div class="card" style="animation: slideUp 0.5s ease">
                <div class="card-header">
                    <span class="card-title">📋 Application #${app.id}</span>
                    <span class="badge badge-${app.status}">${app.status}</span>
                </div>
                <div class="app-detail">
                    <div class="app-detail-item">
                        <div class="label">User</div>
                        <div class="value">${escapeHtml(app.user_name)}</div>
                    </div>
                    <div class="app-detail-item">
                        <div class="label">Email</div>
                        <div class="value">${escapeHtml(app.user_email)}</div>
                    </div>
                    <div class="app-detail-item">
                        <div class="label">Requested PDF</div>
                        <div class="value">${escapeHtml(app.pdf_title)}</div>
                    </div>
                    <div class="app-detail-item">
                        <div class="label">AI Score</div>
                        <div class="value">
                            <span class="ai-score ${getScoreClass(app.ai_score)}">
                                ${app.ai_score !== null ? app.ai_score + '/100' : 'N/A'}
                            </span>
                            ${app.ai_score !== null ? `
                            <div class="score-bar">
                                <div class="score-bar-fill" style="width: ${app.ai_score}%; background: ${getScoreColor(app.ai_score)}"></div>
                            </div>` : ''}
                        </div>
                    </div>
                    <div class="app-detail-item">
                        <div class="label">AI Recommendation</div>
                        <div class="value"><span class="badge badge-${app.ai_decision || 'pending'}">${app.ai_decision || 'N/A'}</span></div>
                    </div>
                    <div class="app-detail-item">
                        <div class="label">Submitted</div>
                        <div class="value">${formatDate(app.created_at)}</div>
                    </div>
                    <div class="app-detail-item app-text">
                        <div class="label">Application Text</div>
                        <div class="value">${escapeHtml(app.application_text)}</div>
                    </div>
                </div>
                ${app.status === 'pending' ? `
                <div class="card-actions">
                    <button class="btn btn-success btn-sm" onclick="decideApplication(${app.id}, 'approve')">✅ Approve</button>
                    <button class="btn btn-danger btn-sm" onclick="decideApplication(${app.id}, 'reject')">❌ Reject</button>
                </div>` : `
                <div class="card-actions">
                    <span class="badge badge-${app.admin_decision === 'approve' ? 'approved' : 'rejected'}">
                        Admin: ${app.admin_decision || app.status}
                    </span>
                </div>`}
            </div>
        `).join('');
        const pendingCount = apps.filter(a => a.status === 'pending').length;
        updateStatCount('pending-count', pendingCount);
        updateStatCount('total-apps', apps.length);
    } catch (err) { /* handled */ }
}

// ---- Admin: Decide Application ----
async function decideApplication(id, decision) {
    const action = decision === 'approve' ? 'approve' : 'reject';
    if (!confirm(`Are you sure you want to ${action} this application?`)) return;
    try {
        await api(`/admin/applications/${id}/decide?decision=${decision}`, { method: 'POST' });
        showToast(`Application ${action}d!`, 'success');
        loadApplications();
    } catch (err) { /* handled */ }
}

// ---- Admin: Load Users ----
async function loadUsers() {
    const container = document.getElementById('users-tbody');
    if (!container) return;
    try {
        const users = await api('/admin/users');
        if (users.length === 0) {
            container.innerHTML = `<tr><td colspan="5" class="empty-state" style="text-align: center;"><div class="icon">👥</div><p>No users found</p></td></tr>`;
            return;
        }
        container.innerHTML = users.map(u => `
            <tr>
                <td>${escapeHtml(u.name)}</td>
                <td>${escapeHtml(u.email)}</td>
                <td><span class="badge badge-${u.role === 'admin' ? 'approved' : 'pending'}">${u.role}</span></td>
                <td>${formatDate(u.created_at)}</td>
                <td>
                    ${u.role !== 'admin' ? `<button class="btn btn-danger btn-sm" onclick="deleteUser(${u.id})">🗑 Delete</button>` : '<span style="color: var(--text-muted)">—</span>'}
                </td>
            </tr>
        `).join('');
    } catch (err) { /* handled */ }
}

// ---- Admin: Delete User ----
async function deleteUser(id) {
    if (!confirm('Delete this user? All their applications and permissions will be removed.')) return;
    try {
        await api(`/admin/users/${id}`, { method: 'DELETE' });
        showToast('User deleted', 'success');
        loadUsers();
    } catch (err) { /* handled */ }
}

// ---- User: Load PDFs ----
async function loadUserPDFs() {
    const container = document.getElementById('user-pdfs-list');
    if (!container) return;
    try {
        const pdfs = await api('/user/pdfs');
        if (pdfs.length === 0) {
            container.innerHTML = `<div class="empty-state"><div class="icon">📄</div><p>No PDFs available yet. Check back later!</p></div>`;
            return;
        }
        container.innerHTML = pdfs.map(pdf => `
            <div class="card" style="animation: slideUp 0.5s ease ${Math.random() * 0.3}s both">
                <div class="card-header">
                    <span class="card-title">📄 ${escapeHtml(pdf.title)}</span>
                    ${pdf.has_access ? '<span class="badge badge-approved">Access Granted</span>' :
                pdf.application_status === 'pending' ? '<span class="badge badge-pending">Pending</span>' :
                    pdf.application_status === 'rejected' ? '<span class="badge badge-rejected">Rejected</span>' : ''}
                </div>
                <p class="card-desc">${escapeHtml(pdf.description || 'No description available')}</p>
                <div class="card-meta">
                    <span>📅 ${formatDate(pdf.upload_date)}</span>
                </div>
                <div class="card-actions">
                    ${pdf.has_access ?
                `<button class="btn btn-primary btn-sm" onclick="openViewerModal(${pdf.id}, '${escapeHtml(pdf.title)}')">👁️ Read</button>
                         <button class="btn btn-success btn-sm" onclick="downloadPDF(${pdf.id})">⬇️ Download</button>` :
                !pdf.application_status || pdf.application_status === 'rejected' ?
                    `<button class="btn btn-primary btn-sm" onclick="openApplyModal(${pdf.id}, '${escapeHtml(pdf.title)}')">📝 Request Access</button>` :
                    ''}
                </div>
            </div>
        `).join('');
    } catch (err) { /* handled */ }
}

