                    <button class="btn btn-primary btn-sm" onclick="openViewerModal(${app.pdf_id}, '${escapeHtml(app.pdf_title)}')">👁️ Read PDF</button>
                    <button class="btn btn-success btn-sm" onclick="downloadPDF(${app.pdf_id})">⬇️ Download PDF</button>
                </div>` : ''}
            </div>
        `).join('');
    } catch (err) { /* handled */ }
}

// ---- User: Apply Modal ----
function openApplyModal(pdfId, pdfTitle) {
    const overlay = document.getElementById('apply-modal');
    if (!overlay) return;
    document.getElementById('apply-pdf-id').value = pdfId;
    document.getElementById('apply-pdf-title').textContent = pdfTitle;
    document.getElementById('apply-text').value = '';
    overlay.classList.add('active');
}

function closeApplyModal() {
    const overlay = document.getElementById('apply-modal');
    if (overlay) overlay.classList.remove('active');
}

async function handleSubmitApplication(e) {
    e.preventDefault();
    const pdfId = parseInt(document.getElementById('apply-pdf-id').value);
    const text = document.getElementById('apply-text').value.trim();
    if (!text) {
        showToast('Please write your application', 'error');
        return;
    }
    try {
        const result = await api('/user/apply', {
            method: 'POST',
            body: JSON.stringify({ pdf_id: pdfId, application_text: text }),
        });
        showToast(`Application submitted! AI Score: ${result.ai_score}/100 (${result.ai_recommendation})`, 'success');
        closeApplyModal();
        loadUserPDFs();
        loadMyApplications();
    } catch (err) { /* handled */ }
}

// ---- User: Download PDF ----
function downloadPDF(pdfId) {
    window.location.href = `/user/download/${pdfId}`;
}

// ---- Helpers ----
function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

function formatDate(dateStr) {
    if (!dateStr || dateStr === 'None') return 'N/A';
    try {
        const d = new Date(dateStr);
        return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    } catch {
        return dateStr;
    }
}

function getScoreClass(score) {
    if (score === null || score === undefined) return '';
    if (score >= 70) return 'high';
    if (score >= 40) return 'medium';
    return 'low';
}

function getScoreColor(score) {
    if (score >= 70) return 'var(--accent-success)';
    if (score >= 40) return 'var(--accent-warning)';
    return 'var(--accent-danger)';
}

function updateStatCount(id, count) {
    const el = document.getElementById(id);
    if (el) el.textContent = count;
}

// ---- User: Password Change ----
function openPasswordModal() {
    const overlay = document.getElementById('password-modal');
    if (overlay) overlay.classList.add('active');
}

function closePasswordModal() {
    const overlay = document.getElementById('password-modal');
    if (overlay) overlay.classList.remove('active');
}

async function handlePasswordChange(e) {
    e.preventDefault();
    const oldPassword = document.getElementById('old-password').value;
    const newPassword = document.getElementById('new-password').value;
    const confirmPassword = document.getElementById('confirm-new-password').value;

    if (newPassword !== confirmPassword) {
        showToast('New passwords do not match', 'error');
        return;
    }

    try {
        await api('/auth/change-password', {
            method: 'POST',
            body: JSON.stringify({ old_password: oldPassword, new_password: newPassword }),
        });
        showToast('Password changed successfully!', 'success');
        closePasswordModal();
        e.target.reset();
    } catch (err) { /* handled */ }
}

// ---- User: PDF Viewer ----
function openViewerModal(pdfId, pdfTitle) {
    const overlay = document.getElementById('viewer-modal');
    const iframe = document.getElementById('pdf-viewer-iframe');
    const title = document.getElementById('viewer-pdf-title');
    if (!overlay || !iframe) return;

    title.textContent = pdfTitle;
    iframe.src = `/user/view/${pdfId}`;
    overlay.classList.add('active');
}

function closeViewerModal() {
    const overlay = document.getElementById('viewer-modal');
    const iframe = document.getElementById('pdf-viewer-iframe');
    if (overlay) overlay.classList.remove('active');
    if (iframe) iframe.src = '';
}
