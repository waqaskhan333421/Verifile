                    <span class="card-title">📋 ${escapeHtml(app.pdf_title)}</span>
                    <span class="badge badge-${app.status}">${app.status}</span>
                </div>
                <div class="app-detail">
                    <div class="app-detail-item app-text">
                        <div class="label">Your Application</div>
                        <div class="value">${escapeHtml(app.application_text)}</div>
                    </div>
                    <div class="app-detail-item">
                        <div class="label">AI Score</div>
                        <div class="value">
                            <span class="ai-score ${getScoreClass(app.ai_score)}">
